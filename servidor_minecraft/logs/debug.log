    "2.10.0": "Updated to 1.19.4 with many QoL changes\n\nChangelog:\nhttps://gitlab.com/modding-legacy/structure-gel-api/-/blob/1.19.x/changelogs/1.19.4-v2.10.0.md\n"
  },
  "1.19.3": {
    "2.9.0": "This update comes with _many_ changes and additions to the Building Tool, Data Handlers, and Dynamic Spawners. This will be the last feature update to 1.19.3, unless major bugs are discovered.\n\nhttps://gitlab.com/modding-legacy/structure-gel-api/-/blob/1.19.x/changelogs/1.19.3-v2.9.0.md"
  },
  "1.19.2": {
    "2.7.2": "Fixed a lockup that could occur during worldgen"
  }
}
